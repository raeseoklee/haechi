{
  "aicelPlugin": {
    "id": "example-custom-filter",
    "version": "0.1.0",
    "kind": "filter-engine",
    "runtime": "node",
    "entrypoint": "./dist/index.js",
    "compatibility": {
      "aicelCore": ">=0.2.0 <0.3.0"
    },
    "capabilities": {
      "readsPlaintext": true,
      "writesPlaintext": false,
      "networkEgress": false,
      "fileWrite": false,
      "auditWrite": false,
      "externalSecrets": false
    },
    "dataHandling": {
      "storesPayload": false,
      "retention": "none",
      "logsRawPayload": false
    },
    "tests": {
      "conformance": "./fixtures/conformance.json",
      "negative": "./fixtures/negative.json"
    }
  }
}
